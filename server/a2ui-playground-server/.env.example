# —— OpenAI（推荐：模型对话 POST /api/chat）——
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# 官方 OpenAI 可改为 gpt-4o-mini 等；DashScope 兼容模式常用 qwen3.5-plus
OPENAI_MODEL=qwen3.5-plus

# POST /api/agent：强制使用随机 mock（不调用 LLM）；也可用 ?mock=1
# AGENT_USE_MOCK=1

# A2UI Agent 详细调试（每条 SSE 事件类型、LLM 原始输出片段等）；不设则仍有请求/完成摘要日志
# A2UI_AGENT_DEBUG=1

# 设为 0 可关闭：每次 LLM /api/agent 将完整 system prompt 追加写入日志文件（不写 console）
# A2UI_AGENT_LOG_SYSTEM_PROMPT=0
# 日志路径（可选；默认 server/a2ui-playground-server/logs/a2ui-agent-system-prompt.log）
# A2UI_AGENT_SYSTEM_PROMPT_LOG_PATH=./logs/my-system-prompt.log

# 设为 0 可关闭：每次 LLM 成功返回后，将 assistant 完整原文追加写入日志（对照缓冲/SSE 用）
# A2UI_AGENT_LOG_LLM_RAW=0
# 路径（可选；默认 logs/a2ui-agent-llm-raw.log）
# A2UI_AGENT_LLM_RAW_LOG_PATH=./logs/my-llm-raw.log

# —— 兼容：其它 OpenAI 协议网关（未配置 OPENAI_API_KEY 时使用）——
# LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# LLM_API_KEY=

# 服务端口（可选）
# PORT=3847
