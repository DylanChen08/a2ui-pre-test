{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true
  },
  "references": [
    { "path": "./packages/a2ui-core" },
    { "path": "./packages/a2ui-react" },
    { "path": "./web/a2ui-playground" },
    { "path": "./server/a2ui-playground-server" }
  ]
}


